   "source": [
    "import qrcode\n",
    "\n",
    "# Datos que contendrá el código QR\n",
    "datos = \"https://github.com/LovecraftianCode\"\n",
    "\n",
    "# Generar el código QR\n",
    "img = qrcode.make(datos)\n",
    "\n",
    "# Guardar la imagen\n",
    "img.save(\"codigo_qr.png\")\n",
    "\n",
    "print(\"Código QR generado exitosamente.\")"
   ]
  },
